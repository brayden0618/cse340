<%- include('partials/header') %>

<main>
    <h1><%= project.title %></h1>

    <a href="/edit-project/<%= project.project_id %>" class="btn">Edit Project</a>

    <a href="/assign-categories/<%= project.project_id %>" class="btn">
        Assign Categories
    </a>

    <p><strong>Organization:</strong> <%= project.organization_name %></p>
    <p><strong>Date:</strong> <%= new Date(project.project_date).toLocaleDateString() %></p>
    <p><strong>Location:</strong> <%= project.location %></p>
    <p><%= project.description %></p>

    <h3>Categories</h3>

    <div>
        <% if (categories && categories.length > 0) { %>

            <% categories.forEach(category => { %>
                <a href="/category/<%= category.category_id %>">
                    <span class="category-tag">
                        <%= category.name %>
                    </span>
                </a>
            <% }) %>

        <% } else { %>
            <p>No categories assigned.</p>
        <% } %>
    </div>
</main>

<%- include('partials/footer') %>