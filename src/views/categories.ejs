<%- include('partials/header') %>

<main>

<h1><%= title %></h1>

<ul>
<% if (categories && categories.length > 0) { %>

    <% categories.forEach(category => { %>
        <li><%= category.name %></li>
    <% }) %>

<% } else { %>

    <li>No categories available.</li>

<% } %>
</ul>

</main>

<%- include('partials/footer') %>