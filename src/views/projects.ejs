<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <p>Here are some of our recent projects:</p>

    <ul>
        <% if (projects && projects.length > 0) { %>
            <% projects.forEach(project => { %>
                <li>
                    <%= new Date(project.date).toLocaleDateString() %>:
                    <%= project.title %>
                    (<%= project.organization_name %>)
                </li>

                <li>
                    <a href="/project/<%= project.project_id %>">View Details</a>
                </li>

                <li>
                    <a href="/organization/<%= project.organization_id %>">View Organization</a>
                </li>
                <li>
                    <a href="/edit-project/<%= project.project_id %>">Edit Project</a>
                </li>
            <% }) %>
        <% } else { %>
            <li>No projects available.</li>
        <% } %>
    </ul>
    <p><a href="/new-project">Add a New Service Project</a></p>
</main>

<%- include('partials/footer') %>