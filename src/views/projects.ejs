<%- include('partials/header') %>

<main>
    <h1>Service Projects</h1>

    <div class="projects-container">
        <% projects.forEach(project => { %>
            <div class="project-card">
                
                <h3>
                    <a href="/project/<%= project.project_id %>">
                        <%= project.title %>
                    </a>
                </h3>

                <p><strong>Organization:</strong> <%= project.organization_name %></p>
                <p><strong>Location:</strong> <%= project.location %></p>
                <p><strong>Date:</strong> <%= new Date(project.project_date).toLocaleDateString() %></p>

                <a href="/project/<%= project.project_id %>" class="btn">View Details</a>

            </div>
        <% }) %>
    </div>
</main>

<%- include('partials/footer') %>