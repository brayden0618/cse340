<%- include('partials/header') %>

<main>

<h1><%= category.name %></h1>

<h3>Service Projects</h3>

<ul>

<% if (projects && projects.length > 0) { %>

    <% projects.forEach(project => { %>

        <li>
            <a href="/project/<%= project.project_id %>">
                <%= project.title %>
            </a>
            - <%= project.location %>
            (<%= new Date(project.project_date).toLocaleDateString() %>)
        </li>

    <% }) %>

<% } else { %>

    <li>No projects in this category.</li>

<% } %>

</ul>

</main>

<%- include('partials/footer') %>